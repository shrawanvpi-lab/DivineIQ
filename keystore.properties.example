# Copy this file to "keystore.properties" (git-ignored) at the project root
# to sign local release builds with your own key. If this file is absent,
# release builds automatically fall back to debug signing so `assembleRelease`
# still succeeds (used by CI). The same values can instead be supplied as
# environment variables, which is what GitHub Actions uses:
#   DIVINEIQ_KEYSTORE_PATH, DIVINEIQ_KEYSTORE_PASSWORD,
#   DIVINEIQ_KEY_ALIAS, DIVINEIQ_KEY_PASSWORD
storeFile=/absolute/path/to/divineiq-release.jks
storePassword=your-keystore-password
keyAlias=divineiq
keyPassword=your-key-password
